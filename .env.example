# Morv — environment template

# BYOM (pick your provider)
OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# XAI_API_KEY=xai-...

# Agent wallet on Base (USDC)
# MORV_WALLET_PRIVATE_KEY=0x...
# BASE_RPC_URL=https://mainnet.base.org

# Or Bankr wallet on Base
# BANKR_API_KEY=bk_...
# BANKR_AGENT_ADDRESS=0x...

# x402 provider: bankr (default) | morv
# X402_PROVIDER=bankr

# Optional — Morv gateway (https://morv.run)
# MORV_API_BASE_URL=https://api.morv.run
# MORV_API_KEY=mv_...
