# Morv — environment template (open source)

# BYOM
OPENAI_API_KEY=sk-...

# Hosted Morv API (optional — enables credits + marketplace)
# MORV_API_BASE_URL=https://your-backend.up.railway.app
# MORV_API_KEY=mv_...

# Platform wallet — pays onchain when using credits or x402
# Bankr (recommended on Base)
# BANKR_API_KEY=bk_...
# BANKR_AGENT_ADDRESS=0x...

# Or direct Base wallet
# MORV_WALLET_PRIVATE_KEY=0x...
# BASE_RPC_URL=https://mainnet.base.org

# x402 provider: bankr (default) | morv
# X402_PROVIDER=bankr
